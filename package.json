{
  "name": "copy-path-line",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.1",
  "publisher": "dmxiaoshubao",
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "dmxiaoshubao",
    "url": "https://github.com/dmxiaoshubao"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dmxiaoshubao/copy-path-line.git"
  },
  "bugs": {
    "url": "https://github.com/dmxiaoshubao/copy-path-line/issues"
  },
  "homepage": "https://github.com/dmxiaoshubao/copy-path-line#readme",
  "keywords": [
    "vscode",
    "extension",
    "path",
    "line",
    "clipboard",
    "line-number",
    "relative-path",
    "absolute-path",
    "copy"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1F3B5B",
    "theme": "dark"
  },
  "pricing": "Free",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Formatters"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copyPathLine.copyRelativePathWithLine",
        "title": "%commands.copyRelative.title%",
        "category": "%commands.category%"
      },
      {
        "command": "copyPathLine.copyAbsolutePathWithLine",
        "title": "%commands.copyAbsolute.title%",
        "category": "%commands.category%"
      }
    ],
    "keybindings": [
      {
        "command": "copyPathLine.copyRelativePathWithLine",
        "key": "shift+cmd+c",
        "mac": "shift+cmd+c",
        "when": "editorTextFocus && resourceScheme == file"
      },
      {
        "command": "copyPathLine.copyRelativePathWithLine",
        "key": "shift+ctrl+c",
        "win": "shift+ctrl+c",
        "linux": "shift+ctrl+c",
        "when": "editorTextFocus && resourceScheme == file"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "copyPathLine.copyRelativePathWithLine",
          "when": "resourceScheme == file",
          "group": "navigation@10"
        },
        {
          "command": "copyPathLine.copyAbsolutePathWithLine",
          "when": "resourceScheme == file",
          "group": "navigation@11"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "pretest": "npm run compile",
    "test": "npm run test:host",
    "test:host": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.30",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^10.8.2",
    "typescript": "^5.8.3"
  }
}
